---
import MonthHeader from "./MonthHeader.astro";

interface Props {
  days: Array<{
    day: number;
    weekday: string;
    monthName: string;
  }>;
  sortedEvents: Array<{
    id: string;
    title: string;
    start: string;
    end: string;
    description: string;
    image: string | null;
    tags: string[];
    color: string;
    url: string | null;
    location: string;
    hora: string;
  }>;
  TOTAL_DAYS: number;
  today: Date;
  diffDays: (a: Date, b: Date) => number;
  getTextColor: (bgColor: string) => string;
  truncateText: (text: string, maxLength: number) => string;
  MAX_TITLE_LENGTH: number;
  toUY: (iso: string) => Date;
}

const {
  days,
  sortedEvents,
  TOTAL_DAYS,
  today,
  diffDays,
  getTextColor,
  truncateText,
  MAX_TITLE_LENGTH,
  toUY,
} = Astro.props;

const rows: number[] = [];

function getRow(start: number, end: number): number {
  for (let i = 0; i < rows.length; i++) {
    if (start > rows[i]) {
      rows[i] = end;
      return i + 3;
    }
  }
  rows.push(end);
  return rows.length + 2;
}
---

<div class="hidden md:block">
  <MonthHeader initialMonth={days[0]?.monthName || ""} elementId="monthLabel" />

  <div
    id="timeline"
    class="relative overflow-x-auto min-h-[70vh]"
    role="region"
    aria-label="Línea de tiempo de eventos"
  >
    <!-- Hint de arrastre: overlay dentro del timeline, no ocupa espacio -->
    <div
      id="dragHint"
      class="sticky left-0 top-0 z-10 inline-flex items-center gap-2 text-neutral-400 text-sm py-1 select-none pointer-events-none transition-opacity duration-500"
      aria-hidden="true"
    >
      <span>←→</span>
      <span>Arrastrá o usá las flechas del teclado para navegar</span>
    </div>
    <div
      class="grid gap-x-14 gap-y-5 items-start pr-[30vw]"
      style={`grid-template-columns: repeat(${days.length}, 180px);`}
    >
      {
        days.map((d) => (
          <div
            class="day-col text-center text-[18px] italic text-neutral-500
                 font-[PPEditorialNew]"
            data-month={d.monthName}
          >
            {d.weekday}
          </div>
        ))
      }

      {
        days.map((d) => (
          <div
            class="text-center text-[20px] font-normal pb-3
                 border-b border-neutral-300
                 font-[PPEditorialNew]"
          >
            {d.day}
          </div>
        ))
      }

      {
        sortedEvents.map((ev) => {
          const start = toUY(ev.start);
          const end = toUY(ev.end);

          const startOffset = diffDays(start, today);
          const endOffset = diffDays(end, today);

          if (endOffset < 0 || startOffset > TOTAL_DAYS - 1) return null;

          const colStart = Math.max(1, startOffset + 1);
          const colEnd = Math.min(TOTAL_DAYS, endOffset + 1);
          const span = colEnd - colStart + 1;

          const row = getRow(startOffset, endOffset);
          const bg = ev.color;
          const text = getTextColor(bg);

          return (
            <a
              href="#"
              data-title={ev.title}
              data-start={ev.start}
              data-end={ev.end}
              data-description={ev.description}
              data-image={ev.image}
              data-tags={ev.tags.join(",")}
              data-url={ev.url}
              data-color={bg}
              data-location={ev.location}
              data-hora={ev.hora}
              class="event-link relative h-16 flex items-center overflow-hidden
       px-5 rounded-2xl
       font-[PPEditorialNew] transition hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2"
              style={`grid-column:${colStart}/span ${span};grid-row:${row};background-color:${bg};color:${text};`}
              role="button"
              tabindex="0"
              aria-label={`Evento: ${ev.title}`}
            >
              <span class="text-[15px] font-normal truncate">{ev.title}</span>
            </a>
          );
        })
      }
    </div>
  </div>
</div>

<script>
  const monthLabel = document.getElementById("monthLabel");
  const timeline = document.getElementById("timeline") as HTMLElement | null;
  const dayCols = document.querySelectorAll<HTMLElement>(".day-col");
  const dragHint = document.getElementById("dragHint");

  /* ---- Actualizar mes al hacer scroll ---- */
  timeline?.addEventListener("scroll", () => {
    if (dayCols.length === 0) return;
    const timelineRect = timeline.getBoundingClientRect();
    let visibleMonth: string | null = null;
    dayCols.forEach((col) => {
      const colRect = col.getBoundingClientRect();
      if (colRect.left < timelineRect.right && colRect.right > timelineRect.left) {
        if (!visibleMonth) visibleMonth = col.getAttribute("data-month");
      }
    });
    if (visibleMonth && monthLabel) monthLabel.textContent = visibleMonth;
  });

  /* ---- Ocultar hint tras primer scroll o interacción ---- */
  function hideHint() {
    if (dragHint) {
      dragHint.style.opacity = "0";
      dragHint.style.pointerEvents = "none";
    }
  }
  timeline?.addEventListener("scroll", hideHint, { once: true });
  timeline?.addEventListener("keydown", hideHint, { once: true });

  /* ---- Drag para arrastrar ---- */
  let isDown = false;
  let startX: number;
  let scrollLeft: number;

  timeline?.addEventListener("mousedown", (e: MouseEvent) => {
    isDown = true;
    startX = e.pageX - timeline.offsetLeft;
    scrollLeft = timeline.scrollLeft;
    timeline.style.cursor = "grabbing";
  });

  timeline?.addEventListener("mouseleave", () => {
    isDown = false;
    timeline.style.cursor = "";
  });

  timeline?.addEventListener("mouseup", () => {
    isDown = false;
    timeline.style.cursor = "";
  });

  timeline?.addEventListener("mousemove", (e: MouseEvent) => {
    if (!isDown) return;
    e.preventDefault();
    const x = e.pageX - timeline.offsetLeft;
    timeline.scrollLeft = scrollLeft - (x - startX);
  });

  /* ---- Scroll horizontal con rueda – escucha en toda la página ---- */
  document.addEventListener(
    "wheel",
    (e: WheelEvent) => {
      if (!timeline) return;
      // No interceptar si el popup está abierto
      const popupOpen = document.getElementById("eventPopup")?.getAttribute("aria-hidden") === "false";
      if (popupOpen) return;
      if (timeline.scrollWidth > timeline.clientWidth) {
        e.preventDefault();
        timeline.scrollLeft += e.deltaY + e.deltaX;
      }
    },
    { passive: false },
  );

  /* ---- Navegación con teclado (flechas) – global, sin necesidad de click ---- */
  const COL_WIDTH = 180 + 56; // 180px col + gap-x-14 (3.5rem = 56px)

  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (!timeline) return;
    // No interceptar si el foco está en un input, textarea, select o popup abierto
    const tag = (document.activeElement as HTMLElement)?.tagName ?? "";
    const popupOpen = document.getElementById("eventPopup")?.getAttribute("aria-hidden") === "false";
    if (["INPUT", "TEXTAREA", "SELECT"].includes(tag) || popupOpen) return;

    if (e.key === "ArrowRight") {
      e.preventDefault();
      timeline.scrollLeft += COL_WIDTH;
    } else if (e.key === "ArrowLeft") {
      e.preventDefault();
      timeline.scrollLeft -= COL_WIDTH;
    } else if (e.key === "Home") {
      e.preventDefault();
      timeline.scrollLeft = 0;
    } else if (e.key === "End") {
      e.preventDefault();
      timeline.scrollLeft = timeline.scrollWidth;
    }
  });

  /* ---- Scroll al día de hoy al cargar ---- */
  // El día de hoy es siempre la columna 1 (índice 0), así que empezamos al inicio
  // pero si el usuario ya tiene scroll guardado, respetarlo
  if (!sessionStorage.getItem("timelineScrolled")) {
    timeline && (timeline.scrollLeft = 0);
  }
</script>
